{
  "name": "stitches-studio",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "concurrently \"vite --config frontend/vite.config.js\" \"node --env-file-if-exists=backend/.env --watch backend/index.js\"",
    "dev:frontend": "vite --config frontend/vite.config.js",
    "dev:backend": "node --env-file-if-exists=backend/.env --watch backend/index.js",
    "build": "vite build --config frontend/vite.config.js",
    "build:frontend": "vite build --config frontend/vite.config.js",
    "start": "node --env-file-if-exists=backend/.env backend/index.js",
    "start:backend": "node --env-file-if-exists=backend/.env backend/index.js"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^6.0.3",
    "axios": "^1.18.1",
    "concurrently": "^10.0.3",
    "express": "^5.2.1",
    "form-data": "^4.0.6",
    "lucide-react": "^1.23.0",
    "multer": "^2.2.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-router-dom": "^7.18.1",
    "vite": "^8.1.3"
  }
}
